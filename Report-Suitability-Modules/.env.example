# Used by: report-processor.py, food-sutability.py
GEMINI_API_KEY=your_gemini_api_key_here

# Used by: report-processor.py (Google Document AI OCR)
GCP_PROJECT_ID=your_gcp_project_id
GCP_LOCATION=your_gcp_location   # e.g. us / eu (or a region like us-central1, depending on your processor)
GCP_PROCESSOR_ID=your_document_ai_processor_id

# Absolute path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
